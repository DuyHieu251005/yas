pipeline {
    agent any

    parameters {
        string(name: 'cart_branch', defaultValue: 'main', description: 'Branch cho cart')
        string(name: 'customer_branch', defaultValue: 'main', description: 'Branch cho customer')
        string(name: 'inventory_branch', defaultValue: 'main', description: 'Branch cho inventory')
        string(name: 'location_branch', defaultValue: 'main', description: 'Branch cho location')
        string(name: 'media_branch', defaultValue: 'main', description: 'Branch cho media')
        string(name: 'order_branch', defaultValue: 'main', description: 'Branch cho order')
        string(name: 'payment_branch', defaultValue: 'main', description: 'Branch cho payment')
        string(name: 'payment_paypal_branch', defaultValue: 'main', description: 'Branch cho payment-paypal')
        string(name: 'product_branch', defaultValue: 'main', description: 'Branch cho product')
        string(name: 'promotion_branch', defaultValue: 'main', description: 'Branch cho promotion')
        string(name: 'rating_branch', defaultValue: 'main', description: 'Branch cho rating')
        string(name: 'recommendation_branch', defaultValue: 'main', description: 'Branch cho recommendation')
        string(name: 'search_branch', defaultValue: 'main', description: 'Branch cho search')
        string(name: 'tax_branch', defaultValue: 'main', description: 'Branch cho tax')
        string(name: 'webhook_branch', defaultValue: 'main', description: 'Branch cho webhook')
        string(name: 'backoffice_branch', defaultValue: 'main', description: 'Branch cho backoffice')
        string(name: 'storefront_branch', defaultValue: 'main', description: 'Branch cho storefront')
        string(name: 'storefront_bff_branch', defaultValue: 'main', description: 'Branch cho storefront-bff')
        string(name: 'backoffice_bff_branch', defaultValue: 'main', description: 'Branch cho backoffice-bff')
        string(name: 'sampledata_branch', defaultValue: 'main', description: 'Branch cho sampledata')
    }

    environment {
        DOCKERHUB_USERNAME = 'duyhieu2005'
        K8S_NAMESPACE = 'yas-app'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Deploy Services to K8s') {
            steps {
                script {
                    // Map: service_name -> [chart_name, branch_param]
                    // chart_name phải khớp với tên thư mục trong k8s/charts/
                    def services = [
                        ['yas-configuration', 'yas-configuration', 'main'],
                        ['swagger-ui',      'swagger-ui',      'main'],
                        ['cart',            'cart',            params.cart_branch],
                        ['customer',        'customer',        params.customer_branch],
                        ['inventory',       'inventory',       params.inventory_branch],
                        ['location',        'location',        params.location_branch],
                        ['media',           'media',           params.media_branch],
                        ['order',           'order',           params.order_branch],
                        ['payment',         'payment',         params.payment_branch],
                        ['payment-paypal',  'payment-paypal',  params.payment_paypal_branch],
                        ['product',         'product',         params.product_branch],
                        ['promotion',       'promotion',       params.promotion_branch],
                        ['rating',          'rating',          params.rating_branch],
                        ['recommendation',  'recommendation',  params.recommendation_branch],
                        ['search',          'search',          params.search_branch],
                        ['tax',             'tax',             params.tax_branch],
                        ['webhook',         'webhook',         params.webhook_branch],
                        ['backoffice',      'backoffice-ui',   params.backoffice_branch],
                        ['storefront',      'storefront-ui',   params.storefront_branch],
                        ['storefront-bff',  'storefront-bff',  params.storefront_bff_branch],
                        ['backoffice-bff',  'backoffice-bff',  params.backoffice_bff_branch],
                        ['sampledata',      'sampledata',      params.sampledata_branch]
                    ]

                    for (svc in services) {
                        def serviceName = svc[0]
                        def chartName   = svc[1]
                        def branch      = svc[2]

                        def tagToDeploy = 'latest'

                        if (branch && branch != 'main') {
                            def commitId = sh(script: "git ls-remote origin ${branch} | head -n 1 | cut -c1-7", returnStdout: true).trim()
                            if (commitId) {
                                tagToDeploy = commitId
                            } else {
                                echo "CẢNH BÁO: Không tìm thấy commit cho nhánh ${branch}, dùng tag latest."
                            }
                        }

                        echo "=> Đang Deploy service: ${serviceName} (chart: ${chartName}) - Tag: ${tagToDeploy}"

                        sh """
                        helm dependency build k8s/charts/${chartName} 2>/dev/null || true
                        helm upgrade --install ${serviceName} k8s/charts/${chartName} \
                            --namespace ${env.K8S_NAMESPACE} --create-namespace \
                            --set backend.image.repository=${env.DOCKERHUB_USERNAME}/yas-${serviceName} \
                            --set ui.image.repository=${env.DOCKERHUB_USERNAME}/yas-${serviceName} \
                            --set backend.image.tag=${tagToDeploy} \
                            --set ui.image.tag=${tagToDeploy} \
                            --set backend.image.pullPolicy=Always \
                            --set ui.image.pullPolicy=Always \
                            --set backend.serviceMonitor.enabled=false \
                            --set backend.service.type=NodePort \
                            --set ui.service.type=NodePort
                        """
                    }
                }
            }
        }

        stage('Get Endpoints') {
            steps {
                script {
                    echo "============== ENDPOINTS ĐÃ DEPLOY =============="
                    sh "kubectl get svc -n ${env.K8S_NAMESPACE}"
                    
                    echo "============== HƯỚNG DẪN TRUY CẬP (YÊU CẦU MỤC 4) =============="
                    def storefrontPort = sh(script: "kubectl get svc storefront-ui -n ${env.K8S_NAMESPACE} -o jsonpath='{.spec.ports[?(@.port==3000)].nodePort}'", returnStdout: true).trim()
                    def backofficePort = sh(script: "kubectl get svc backoffice-ui -n ${env.K8S_NAMESPACE} -o jsonpath='{.spec.ports[?(@.port==3000)].nodePort}'", returnStdout: true).trim()

                    echo """
                    ĐỂ DEVELOPER TEST TRỰC TIẾP QUA DOMAIN NAME (MỤC 4 ĐỒ ÁN):
                    
                    1. Mở file C:\\Windows\\System32\\drivers\\etc\\hosts (bằng quyền Administrator)
                    2. Thêm 2 dòng sau vào cuối file để trỏ tới Worker Node K8s (192.168.1.22):
                       192.168.1.22 storefront.yas.local.com
                       192.168.1.22 backoffice.yas.local.com
                       
                    3. Mở trình duyệt và truy cập (theo định dạng domain name:port):
                       👉 Storefront: http://storefront.yas.local.com:${storefrontPort}
                       👉 Backoffice: http://backoffice.yas.local.com:${backofficePort}
                    """

                    // In hyperlink đến job Cleanup_Deployment (MỤC 5 ĐỒ ÁN)
                    def cleanupUrl = "${env.JENKINS_URL}job/Delete_Deployment/"
                    echo "============== MỤC 5: XÓA TRIỂN KHAI =============="
                    echo "Sau khi test xong, bấm vào link sau để chạy job dọn dẹp môi trường:"
                    echo "🗑️  Cleanup Job: ${cleanupUrl}"
                }
            }
        }
    }
}
